# Development-only values. Copy this file to .env and choose a local password.
POSTGRES_DB=auth_test_ai
POSTGRES_USER=auth_test_ai
POSTGRES_PASSWORD=change-me-for-local-development
POSTGRES_PORT=5432
AUTH_TEST_AI_ENV=development
DATABASE_URL=postgresql+psycopg://auth_test_ai:change-me-for-local-development@localhost:5432/auth_test_ai
TEST_DATABASE_URL=postgresql+psycopg://auth_test_ai:change-me-for-local-development@localhost:5432/auth_test_ai_test
# Rejected placeholder: production requires a randomly generated secret.
SECRET_KEY=REPLACE_WITH_RANDOM_PRODUCTION_SECRET
SESSION_COOKIE_NAME=auth_test_ai_session
SESSION_IDLE_MINUTES=30
SESSION_ABSOLUTE_HOURS=8
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15
LOGIN_RATE_LIMIT=10 per minute
RATELIMIT_STORAGE_URI=memory://
MAX_CONTENT_LENGTH=16384
ARGON2_TIME_COST=3
ARGON2_MEMORY_COST=65536
ARGON2_PARALLELISM=4
ALLOW_DEV_SEED=false

# Synthetic local seed values only. Replace all values in the untracked .env file.
SEED_ADMIN_PASSWORD=replace-this-fictitious-admin-password
SEED_USER_ONE_PASSWORD=replace-this-fictitious-user-one-password
SEED_USER_TWO_PASSWORD=replace-this-fictitious-user-two-password
SEED_INACTIVE_PASSWORD=replace-this-fictitious-inactive-password
SEED_LOCKOUT_PASSWORD=replace-this-fictitious-lockout-password
